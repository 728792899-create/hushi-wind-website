NODE_ENV=production
DEPLOYMENT_MODE=single-instance
DATABASE_URL=file:./staging.db
PUBLIC_SITE_URL=https://staging.example.com
PUBLIC_ADMIN_URL=https://admin-staging.example.com
API_PUBLIC_URL=https://api-staging.example.com
UPLOAD_PUBLIC_BASE=https://api-staging.example.com
ALLOWED_ORIGINS=https://staging.example.com,https://admin-staging.example.com
ADMIN_USERNAME=staging_ops
ADMIN_PASSWORD=Replace-Staging-Credential-2026!
ADMIN_TOKEN_SECRET=replace-with-a-64-character-random-staging-secret
ADMIN_TOKEN_TTL_MS=7200000
RATE_LIMIT_STORE=memory
UPLOAD_STORAGE=local
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
OBSERVABILITY_REQUIRED=false
