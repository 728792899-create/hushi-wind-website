NODE_ENV=production
DEPLOYMENT_MODE=multi-instance
DATABASE_URL="postgresql://hushi_app:replace-password@postgres:5432/hushi_prod?schema=public"
PUBLIC_SITE_URL=https://www.your-company-domain.com
PUBLIC_ADMIN_URL=https://admin.your-company-domain.com
API_PUBLIC_URL=https://api.your-company-domain.com
UPLOAD_PUBLIC_BASE=https://api.your-company-domain.com
ALLOWED_ORIGINS=https://www.your-company-domain.com,https://your-company-domain.com,https://admin.your-company-domain.com

# Replace every value before launch. Production will refuse unsafe defaults.
ADMIN_USERNAME=ops_admin
ADMIN_PASSWORD=Replace-With-A-Strong-Password-2026!
ADMIN_TOKEN_SECRET=replace-with-a-64-character-random-token-secret-before-launch
ADMIN_TOKEN_TTL_MS=7200000
ADMIN_IP_ALLOWLIST=
SENSITIVE_CONFIRMATION_TEXT=确认执行

PUBLIC_FORM_RATE_WINDOW_MS=600000
PUBLIC_FORM_RATE_LIMIT=5
PUBLIC_FORM_MIN_ELAPSED_MS=1800
PUBLIC_FORM_MAX_AGE_MS=3600000

API_RATE_WINDOW_MS=60000
API_RATE_LIMIT=180
RATE_LIMIT_STORE=redis
REDIS_URL=redis://redis:6379/0
MAX_UPLOAD_BYTES=20971520
MAX_IMAGE_PIXELS=24000000
CLAMAV_SCAN_COMMAND=

UPLOAD_STORAGE=s3
S3_BUCKET=hushi-production
S3_REGION=ap-southeast-1
S3_ENDPOINT=
S3_PUBLIC_BASE=https://cdn.your-company-domain.com
S3_PREFIX=uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=
ANALYTICS_RETENTION_DAYS=180
API_LOG_RETENTION_DAYS=90
ALERT_RETENTION_DAYS=180
BACKUP_RETENTION_DAYS=30

OBSERVABILITY_REQUIRED=true
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.05

API_PM2_NAME=company-api
WEB_PM2_NAME=company-web
